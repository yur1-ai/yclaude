{
  "name": "yclaude",
  "version": "0.1.0",
  "description": "Local-first analytics dashboard for Claude Code usage",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "yclaude": "./dist/server/cli.js"
  },
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsup",
    "build:frontend": "cd web && npm run build",
    "dev": "concurrently \"tsup --watch\" \"cd web && vite\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && cd web && tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "commander": "^14.0.3",
    "hono": "^4.12.3",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
