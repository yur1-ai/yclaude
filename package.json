{
  "name": "yclaude",
  "version": "0.1.0",
  "description": "Local-first analytics dashboard for Claude Code usage",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
